{
  "expo": {
    "name": "BookMate",
    "slug": "bookmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookmate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookmate.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.bookmate.app"
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "84e4bedd-700e-49a8-a29c-1ccc99c1229f"
      }
    },
    "updates": {
      "enabled": false
    }
  }
}
